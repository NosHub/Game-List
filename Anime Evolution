							Args = raidName
						}
					)
				end
			end
		end
	end)
end)

local AutoReplay = Tabs.Raid:AddToggle("AutoReplay",{
	Title="Auto Replay Raid",
	Default=false
})
AutoReplay:OnChanged(function()
	task.spawn(function()
		while Options.AutoReplay.Value and SCRIPT_ID == getgenv().NOS_SCRIPT_ID do task.wait(1.5)
			for raidName,enabled in pairs(Options.RaidSelect.Value) do
				if enabled then
					local inRaid = mapsFolder:FindFirstChild(raidName)

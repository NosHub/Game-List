})

local function getStarCount(text)
    local count = 0
    for _ in text:gmatch("🌟") do
        count += 1
    end
    return count
end

local function getTabType(stars)
    if stars == 0 then
        return "Shade", 2
    elseif stars == 1 then
        return "Shiny", 2
    elseif stars == 2 then
        return "Dark", 3
    elseif stars == 3 then
        return "Darker", 4
    end
end

local AutoEvolve = Tabs.Egg:AddToggle("AutoEvolve", {
    Title = "Auto Merge",
    Default = false
})
AutoEvolve:OnChanged(function()
    task.spawn(function()
        while Options.AutoEvolve.Value and SCRIPT_ID == getgenv().NOS_SCRIPT_ID do task.wait()
            pcall(function()
                local petsFolder =
                    game.Players.LocalPlayer.PlayerGui.UI
                    .Frames.Inventory.NewMain.body.lists.Shadows.pets
                local pets = {}
                local canMerge = false
                for _, v in pairs(petsFolder:GetChildren()) do
                    local nameLabel =
                        v:FindFirstChild("Button")
                        and v.Button:FindFirstChild("PetName")
                    if nameLabel then
                        local text = nameLabel.Text
                        local stars = getStarCount(text)
                        local petName = text
                            :gsub("🌟", "")
                            :gsub("%s+", "")
                        local key = petName .. "_" .. stars
                        pets[key] = pets[key] or {}
                        table.insert(pets[key], v.Name)
                    end
                end
                for key, data in pairs(pets) do
                    local stars = tonumber(key:match("_(%d+)"))
                    local tab, need = getTabType(stars)
                    if tab and #data >= need then
                        canMerge = true
                    end
                end
                if canMerge then
                    if Options.MergeUnequipMode.Value == "Unequip All" then
                        Bridge:FireServer("Pets", "UnequipAll")
                        task.wait()
                    end
                    for key, data in pairs(pets) do
                        local stars = tonumber(key:match("_(%d+)"))
                        local tab, need = getTabType(stars)
                        if tab and #data >= need then
                            local ids = {}
                            for i = 1, need do
                                table.insert(ids, data[i])
                            end
                            Bridge:FireServer(
                                "Pets",
                                "SMachine",
                                {
                                    TabType = tab,
                                    PetIDs = ids,
                                    Amount = 500
                                }
                            )
                            task.wait()
                        end
                    end
                end
            end)
        end
    end)
end)


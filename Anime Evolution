Tabs.Raid:AddDropdown("RaidSelect",{
    Title="Select Raid",
    Values=RaidMaps,
    Multi=true,
    Default={1}
})

local AutoRaid = Tabs.Raid:AddToggle("AutoRaid",{Title="Auto Raid",Default=false})
AutoRaid:OnChanged(function()
    task.spawn(function()
        while Options.AutoRaid.Value and SCRIPT_ID == getgenv().NOS_SCRIPT_ID do task.wait(1)
            pcall(function()
                for raidName,enabled in pairs(Options.RaidSelect.Value) do
                    if enabled then
                        local args = {
                            "Enemies",
                            "Bridge",
                            {
                                Module = "RaidSystemServer",
                                FunctionName = "Start",
                                Args = raidName
                            }
                        }
                        Bridge:FireServer(unpack(args))
                    end
                end
            end)
        end
    end)
end)

local ExitWave = 51
Tabs.Raid:AddInput("ExitWaveInput",{
    Title = "Exit At Wave",
    Default = "51",
    Numeric = true,
    Finished = false,
    Callback = function(Value)
        ExitWave = tonumber(Value) or 51
    end
})

local AutoExit = Tabs.Raid:AddToggle("AutoExitRaid",{
    Title = "Auto Exit Raid",
    Default = false
})
AutoExit:OnChanged(function()
    task.spawn(function()
        while Options.AutoExitRaid.Value and SCRIPT_ID == getgenv().NOS_SCRIPT_ID do task.wait()
            pcall(function()
                local text = game:GetService("Players").LocalPlayer.PlayerGui.UI.HUD.RaidInfoBoard.waveValue.Text
                local wave = tonumber(text:match("(%d+)/"))
                if wave and wave >= ExitWave then
                    for i,raidName in pairs(RaidMaps) do
                        local exit = {
                            "Enemies",
                            "Bridge",
                            {
                                Module = "RaidSystemServer",
                                FunctionName = "Leave",
                                Args = raidName
                            }
                        }
                        Bridge:FireServer(unpack(exit))
                    end
                end
            end)
        end
    end)
end)

